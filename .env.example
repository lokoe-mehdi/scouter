# PostgreSQL Configuration
POSTGRES_DB=scouter
POSTGRES_USER=scouter
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD

# ClickHouse Configuration (entrepôt des données de crawl).
# Laisser CLICKHOUSE_PASSWORD vide désactive l'auth ; en prod, mettre un mot de passe fort.
# Le service interne écoute sur http://clickhouse:8123 (CLICKHOUSE_URL est fixé dans compose).
CLICKHOUSE_DB=scouter
CLICKHOUSE_USER=scouter
CLICKHOUSE_PASSWORD=CHANGEME_STRONG_CH_PASSWORD

# --- Page-HTML blob storage --------------------------------------------------
# Crawled page HTML is stored gzip-compressed OUTSIDE the database (it bloated
# ClickHouse). It is keyed by html/<crawl_id>/<page_id>.gz and read back by the
# UI, API, MCP and chatbot.
#
# Leave the S3_* vars empty to store on the local disk (STORAGE_PATH, a volume
# shared between the crawler and the web app). Fill them in to store on any
# S3-compatible bucket instead (data persists long-term — re-fetch a URL months
# later). Switching backends only affects NEW crawls; old crawls keep reading
# from wherever their HTML already is.
#
# STORAGE_PATH is preset to /app/storage in docker-compose; override only off-Docker.
#STORAGE_PATH=./storage
S3_BUCKET=
S3_REGION=
# S3_ENDPOINT: leave empty for AWS S3. For Cloudflare R2 / MinIO / Backblaze B2,
# set the endpoint URL (e.g. https://<account>.r2.cloudflarestorage.com).
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_PREFIX: optional key namespace if the bucket is shared with other data.
S3_PREFIX=
# S3_USE_PATH_STYLE: set true for providers needing path-style addressing (MinIO).
S3_USE_PATH_STYLE=false

# Clé de chiffrement maître (AES-256-GCM) des secrets stockés en base
# (clé API OpenRouter, etc. dans app_settings).
# OBLIGATOIRE : générez la vôtre avec  openssl rand -hex 32
# - Ne réutilisez JAMAIS la valeur bidon ci-dessous (elle est publique).
# - Sa perte rend TOUS les secrets chiffrés irrécupérables → sauvegardez-la
#   au même endroit que vos identifiants de base.
SCOUTER_ENCRYPTION_KEY=CHANGEME_GENERATE_WITH_openssl_rand_hex_32

# --- Limites de ressources par conteneur --------------------------------------
# AUCUNE ÉDITION NÉCESSAIRE en local : scripts/autosize.sh (lancé automatiquement
# par ./start.sh) détecte la RAM et le nombre de cœurs de la machine et calcule
# chaque *_MEM_LIMIT proportionnellement, avec planchers minimum viables. Changer
# de machine → relancer ./start.sh → les limites recalculent toutes seules. Un
# client qui clone et lance ./start.sh chez lui obtient un dimensionnement
# adapté à SA machine sans rien toucher au code.
#
# Une valeur définie ci-dessous (ou dans ton .env) ÉCRASE l'auto-détection pour
# ce conteneur précis — utile pour pinner ClickHouse plus haut si tes rapports
# sont lourds, ou serrer un worker. Les autres restent auto.
#
# DÉPLOIEMENT DIRECT (Coolify, docker compose sans start.sh) : autosize ne tourne
# pas. Lance `bash scripts/autosize.sh /tmp/auto.env` une fois sur ton serveur,
# puis recopie les lignes générées dans l'env de ton hébergeur (ou ici).
#
#CLICKHOUSE_MEM_LIMIT=4g
#POSTGRES_MEM_LIMIT=2g
#SCOUTER_MEM_LIMIT=1g
#CRAWLER_MEM_LIMIT=2g
#WORKER_MEM_LIMIT=384m
#RENDERER_MEM_LIMIT=1g
#MCP_MEM_LIMIT=256m

# Instructions PRODUCTION:
# Configurer ces variables d'environnement directement sur votre serveur
